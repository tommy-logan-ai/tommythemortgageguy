{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.tommythemortgageguy.com" }],
      "destination": "https://tommythemortgageguy.com/$1",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/tools",
      "dest": "/tools.html"
    },
    {
      "src": "/tools.html",
      "dest": "/tools.html"
    },
    {
      "src": "/pre-approval",
      "dest": "/pre-approval.html"
    },
    {
      "src": "/pre-approval.html",
      "dest": "/pre-approval.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
